<% content_for :title, @link.name %>

<div class="w-full max-w-md">
  <h1 class="text-2xl font-bold mb-6"><%= @link.name %></h1>
  <p><%= link_to @link.url, @link.url, target: "_blank", class: "text-blue-600 hover:underline" %></p>
  <div class="mt-6 space-x-4">
    <%= link_to "Edit", edit_link_path(@link), class: "text-gray-600 hover:underline" %>
    <%= link_to "Back", links_path, class: "text-gray-600 hover:underline" %>
  </div>
</div>
