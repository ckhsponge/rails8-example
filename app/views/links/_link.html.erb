<tr id="<%= dom_id(link) %>" class="border-b hover:bg-gray-50">
  <td class="py-2 pr-4"><%= link.name %></td>
  <td class="py-2 pr-4"><%= link_to link.url, link.url, target: "_blank", class: "text-blue-600 hover:underline" %></td>
  <td class="py-2 space-x-2 text-right">
    <%= link_to "Edit", edit_link_path(link), class: "text-gray-600 hover:underline" %>
    <%= button_to "Delete", link_path(link), method: :delete, class: "text-red-600 hover:underline bg-transparent border-0 cursor-pointer p-0", data: { turbo_confirm: "Delete #{link.name}?" } %>
  </td>
</tr>
