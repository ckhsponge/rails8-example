<% content_for :title, "Links" %>

<div class="w-full">
  <h1 class="text-4xl font-bold mb-8">Link Manager</h1>
  <div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold">Links</h2>
    <%= link_to "New Link", new_link_path, class: "bg-black text-white px-4 py-2 rounded hover:bg-gray-800" %>
  </div>

  <% if @links.any? %>
    <table class="w-full border-collapse">
      <thead>
        <tr class="border-b">
          <th class="text-left py-2 pr-4">Name</th>
          <th class="text-left py-2 pr-4">URL</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @links.each do |link| %>
          <tr class="border-b hover:bg-gray-50">
            <td class="py-2 pr-4"><%= link.name %></td>
            <td class="py-2 pr-4"><%= link_to link.url, link.url, target: "_blank", class: "text-blue-600 hover:underline" %></td>
            <td class="py-2 space-x-2 text-right">
              <%= link_to "Edit", edit_link_path(link), class: "text-gray-600 hover:underline" %>
              <%= button_to "Delete", link_path(link), method: :delete, class: "text-red-600 hover:underline bg-transparent border-0 cursor-pointer p-0", data: { turbo_confirm: "Delete #{link.name}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-500">No links yet.</p>
  <% end %>
</div>
