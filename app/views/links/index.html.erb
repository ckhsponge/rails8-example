<% content_for :title, "Links" %>

<%= turbo_stream_from "links" %>

<div class="w-full">
  <h1 class="text-4xl font-bold mb-8">Link Manager</h1>
  <div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold">Links</h2>
    <%= link_to "New Link", new_link_path, class: "bg-black text-white px-4 py-2 rounded hover:bg-gray-800" %>
  </div>

  <table class="w-full border-collapse">
    <thead>
      <tr class="border-b">
        <th class="text-left py-2 pr-4">Name</th>
        <th class="text-left py-2 pr-4">URL</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="links">
      <%= render @links %>
    </tbody>
  </table>
</div>
